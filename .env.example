# =============================================================
# .env.example — Environment Variables Template
# =============================================================
# This file is SAFE to commit to git. It contains only
# placeholder values, never real secrets.
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Open .env and replace every placeholder with your real value
#   3. Never commit .env — it is listed in .gitignore
#
# WHY environment variables (not hardcoding values in Python):
#   - If you write POSTGRES_PASSWORD = "mypassword" in your code
#     and push to GitHub, that password is now public forever.
#   - Environment variables keep secrets out of source code entirely.
#   - Different environments (your laptop, CI server, production)
#     can each have their own .env with different values.
# =============================================================

# --- Stock Symbols to Track ---
# Comma-separated list. These will be fetched and stored.
# AAPL = Apple, GOOGL = Google, MSFT = Microsoft, TSLA = Tesla
STOCK_SYMBOLS=AAPL,GOOGL,MSFT,TSLA

# --- Fetch Schedule ---
# How often (in seconds) to run the ETL pipeline and fetch new prices.
# 60 = once per minute. Yahoo Finance updates ~every 15 seconds during market hours.
FETCH_INTERVAL_SECONDS=60

# --- PostgreSQL Database ---
# These must match the values in docker-compose.yml
#
# POSTGRES_HOST — two different values for two different contexts:
#   localhost  → you're running Python directly on your machine (make test, local dev)
#   postgres   → you're running inside Docker (docker compose up)
# The docker-compose.yml app service OVERRIDES this to "postgres" automatically,
# so you can leave it as "localhost" here for local Python development.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stockmarket
POSTGRES_USER=stockuser
POSTGRES_PASSWORD=changeme_use_a_strong_password_here

# --- Grafana ---
# The admin password for the Grafana web UI (http://localhost:3000)
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana_admin_password

# --- Email Alerts (Gmail SMTP) ---
# IMPORTANT: Do NOT use your real Gmail password here.
# You need a Gmail "App Password" — a special 16-character password
# that only works for this app. Create one at:
# https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.gmail.address@gmail.com
SMTP_PASSWORD=your_16_char_gmail_app_password
ALERT_RECIPIENT=where_to_send_alerts@example.com

# --- Anomaly Detection Thresholds (Z-score method) ---
# HOW Z-SCORE WORKS:
#   z = (latest_price - mean_of_last_N_days) / std_dev_of_last_N_days
#   If |z| > threshold → anomaly detected → email sent.
#
# ANOMALY_Z_SCORE_THRESHOLD:
#   2.5 means "alert if the price is more than 2.5 standard deviations
#   from the recent mean". Only ~1.2% of normal prices exceed this.
ANOMALY_Z_SCORE_THRESHOLD=2.5

# ANOMALY_LOOKBACK_DAYS:
#   How many days of history to use as the baseline for mean + std dev.
#   20 trading days ≈ 1 calendar month of weekday data.
ANOMALY_LOOKBACK_DAYS=20

# --- Application ---
# LOG_LEVEL controls how verbose the app's log output is.
# Options: DEBUG (everything) | INFO (normal) | WARNING | ERROR (problems only)
LOG_LEVEL=INFO
