# =============================================================
# .dockerignore — Exclude files from the Docker build context
# =============================================================
# WHAT IS THE BUILD CONTEXT?
#   When you run "docker compose up --build", Docker sends a copy
#   of the project directory to the Docker daemon (the background
#   service that actually builds and runs containers).
#   This copy is called the "build context".
#
# WHY DO WE NEED .dockerignore?
#   Without it, Docker sends EVERYTHING — including:
#     - venv/ or .venv/  → 200–400 MB of Python packages
#     - .git/            → full git history (can be large)
#     - .env             → YOUR SECRETS (passwords, tokens)
#   This makes each build slow and risks leaking secrets.
#
# WITH .dockerignore:
#   Only files actually used by the Dockerfile's COPY commands
#   are sent. Our Dockerfile only copies:
#     - requirements.txt   (pinned package list)
#     - src/               (application source code)
#   Everything else is excluded here.
#
# FORMAT: Same syntax as .gitignore.
#   - Lines starting with # are comments (ignored)
#   - * matches any sequence of characters within a path segment
#   - **/ matches any number of directories
#   - A leading ! negates a pattern (un-ignores a file)
# =============================================================


# =============================================================
# SECRETS — CRITICAL, never send to Docker daemon
# =============================================================
# If .env reaches the build context and gets baked into an image
# layer, anyone who pulls your image can extract your passwords.
# Belt AND suspenders: it is already in .gitignore, now it is
# excluded from the build context too.
.env
*.env


# =============================================================
# Python virtual environments
# =============================================================
# venv/ and .venv/ are the local Python installs on your machine.
# They are hundreds of MB and machine-specific (e.g. Windows paths
# baked into scripts). The Dockerfile installs packages fresh
# inside the container using pip — these directories are irrelevant.
venv/
.venv/
env/
ENV/
virtualenv/


# =============================================================
# Python cache and compiled bytecode
# =============================================================
# __pycache__/ directories and *.pyc files are bytecode caches
# generated by Python at runtime. They are:
#   - Platform-specific (Windows .pyc ≠ Linux .pyc)
#   - Regenerated automatically on first run
#   - Pointless to include in the image
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.mypy_cache/


# =============================================================
# Tests
# =============================================================
# Tests do not run inside the production container.
# They run locally (make test) or in CI (GitHub Actions).
# Excluding tests keeps the image focused and lean.
tests/
pytest.ini


# =============================================================
# Documentation and planning files
# =============================================================
# These are useful for humans, not for the running application.
docs/
PLAN.md
STRUCTURE.md
CLAUDE.md
README.md


# =============================================================
# Infrastructure / Terraform
# =============================================================
# Terraform files manage cloud infrastructure, not the app itself.
# They should never be inside a Docker image.
infrastructure/
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
*.tfvars


# =============================================================
# Git
# =============================================================
# The full git history and GitHub workflow definitions have no
# place inside a runtime container.
.git/
.gitignore
.github/


# =============================================================
# Monitoring configuration
# =============================================================
# Grafana and Prometheus configs are mounted as volumes (Phase 6/7),
# not copied into the app image.
monitoring/


# =============================================================
# Docker files themselves
# =============================================================
# The docker-compose.yml and Dockerfiles are build-time artifacts.
# There is no reason to COPY them into the running container.
docker/
docker-compose.yml
.dockerignore


# =============================================================
# IDE / Editor
# =============================================================
.vscode/
.idea/
*.swp
*.swo
*~


# =============================================================
# OS-generated files
# =============================================================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
