{
  "__comment": "=================================================================",
  "__comment2": "stock_prices.json — Grafana Dashboard Definition",
  "__comment3": "HOW THIS FILE WORKS:",
  "__comment4": "  Grafana reads this JSON and renders it as a dashboard.",
  "__comment5": "  Each object in 'panels' is one chart or number on the screen.",
  "__comment6": "  Each panel has 'targets' — SQL queries that fetch data.",
  "__comment7": "  Grafana runs those queries against PostgreSQL and plots the results.",
  "__comment8": "EDITING TIPS:",
  "__comment9": "  - Edit visually in the Grafana UI, then export JSON (share icon → Export)",
  "__comment10": "  - Or edit this file directly; Grafana reloads it within 30 seconds.",
  "__comment11": "=================================================================",

  "annotations": {
    "list": []
  },

  "description": "Real-time stock prices — data collected by the ETL pipeline every 60 seconds",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],

  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "AAPL — Apple",
      "description": "Most recently fetched price. Updates every 60 seconds.",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "stock-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "stock-postgres" },
          "rawQuery": true,
          "rawSql": "SELECT price FROM stock_prices WHERE symbol = 'AAPL' ORDER BY fetched_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue",  "value": null },
              { "color": "green", "value": 100  },
              { "color": "orange","value": 300  }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "text": { "titleSize": 14, "valueSize": 32 }
