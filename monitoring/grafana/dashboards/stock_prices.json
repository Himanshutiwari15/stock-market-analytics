    {
      "id": 5,
      "type": "timeseries",
      "title": "Price History — All Stocks",
      "description": "One data point per stock per pipeline run (every 60 seconds). Zoom in with your mouse, or change the time picker top-right.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "postgres", "uid": "stock-postgres" },
      "targets": [
        {
          "refId": "AAPL",
          "datasource": { "type": "postgres", "uid": "stock-postgres" },
          "rawQuery": true,
          "rawSql": "SELECT fetched_at AS \"time\", price AS \"AAPL\" FROM stock_prices WHERE symbol = 'AAPL' AND $__timeFilter(fetched_at) ORDER BY fetched_at",
          "format": "time_series"
        },
        {
          "refId": "GOOGL",
          "datasource": { "type": "postgres", "uid": "stock-postgres" },
          "rawQuery": true,
          "rawSql": "SELECT fetched_at AS \"time\", price AS \"GOOGL\" FROM stock_prices WHERE symbol = 'GOOGL' AND $__timeFilter(fetched_at) ORDER BY fetched_at",
          "format": "time_series"
        },
        {
          "refId": "MSFT",
          "datasource": { "type": "postgres", "uid": "stock-postgres" },
          "rawQuery": true,
          "rawSql": "SELECT fetched_at AS \"time\", price AS \"MSFT\" FROM stock_prices WHERE symbol = 'MSFT' AND $__timeFilter(fetched_at) ORDER BY fetched_at",
          "format": "time_series"
        },
        {
          "refId": "TSLA",
          "datasource": { "type": "postgres", "uid": "stock-postgres" },
          "rawQuery": true,
          "rawSql": "SELECT fetched_at AS \"time\", price AS \"TSLA\" FROM stock_prices WHERE symbol = 'TSLA' AND $__timeFilter(fetched_at) ORDER BY fetched_at",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": false,
            "axisPlacement": "auto",
            "axisLabel": "Price (USD)",
            "scaleDistribution": { "type": "linear" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "green", "value": null } ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "min", "max"]
        }
      }
    },

    {
      "id": 6,
      "type": "table",
      "title": "Latest Prices — Detail View",
      "description": "The 20 most recent rows across all stocks. Useful for verifying the pipeline is inserting data.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "postgres", "uid": "stock-postgres" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "stock-postgres" },
          "rawQuery": true,
          "rawSql": "SELECT symbol, price, fetched_at FROM stock_prices ORDER BY fetched_at DESC LIMIT 20",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "green", "value": null } ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "price" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 },
              { "id": "custom.displayMode", "value": "color-background-solid" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "orange", "value": 300 }
                ]
              }}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "fetched_at" },
            "properties": [
              { "id": "unit", "value": "dateTimeAsIso" },
              { "id": "displayName", "value": "Fetched At (UTC)" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "fetched_at", "desc": true }],
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": ""
        }
      },
      "transformations": []
    }

